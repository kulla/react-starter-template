#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=asdf-utils.sh
source "$SCRIPT_DIR/asdf-utils.sh"

require_dependencies
load_latest_release

INSTALLED_VERSION="$(installed_version)"

if [[ -n "${INSTALLED_VERSION:-}" && "$INSTALLED_VERSION" == "$ASDF_TARGET_VERSION" ]]; then
  log_info "No update needed. asdf is already latest version $ASDF_TARGET_VERSION."
  exit 0
fi

install_latest
